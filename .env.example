# --- General ---
APP_NAME="Medical RAG Chatbot"
APP_ENV=development                # development | staging | production
APP_DEBUG=false
LOG_LEVEL=INFO

# --- Backend API ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:8501

# --- Frontend ---
BACKEND_API_URL=http://localhost:8000/api/v1

# --- RAG engine (Indexation & Moteur RAG) ---
LLM_PROVIDER=ollama                # ollama (local, default) | openai
LLM_MODEL_NAME=qwen2.5:3b
DARIJA_LLM_MODEL_NAME=llama3.1:8b
ANONYMIZED_TELEMETRY=False
LLM_API_KEY=                       # only needed when LLM_PROVIDER=openai
LLM_BASE_URL=http://localhost:11434
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
VECTOR_STORE_PROVIDER=chroma       # chroma
CHUNKS_PATH=./data/chunks_curated
VECTOR_STORE_PATH=./data/vector_store_curated
TOP_K=3
LLM_NUM_PREDICT=256
LLM_TEMPERATURE=0.1
LLM_KEEP_ALIVE=30m

# --- Multilingual bonus ---
ENABLE_DARIJA_SUPPORT=true

# --- Glossary administration ---
ADMIN_DB_PATH=./data/glossary/admin.db
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=              # use at least 12 characters; remove after first startup
ADMIN_SESSION_HOURS=8
